# Base image (generic R + Python support)
FROM rocker/rstudio:latest

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
ENV PATH="/opt/venv/bin:/usr/local/bin:$PATH"

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3-venv \
    python3-dev \
    software-properties-common \
    build-essential \
    zlib1g-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    libffi-dev \
    liblzma-dev \
    tk-dev \
    wget \
    curl \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Install Python 3.10
RUN add-apt-repository ppa:deadsnakes/ppa \
 && apt-get update \
 && apt-get install -y python3.10 python3.10-venv python3.10-distutils \
 && rm -rf /var/lib/apt/lists/*

# Create generic Python virtual environment for SynthCity
RUN python3.10 -m venv /opt/synthcity-env \
 && /opt/synthcity-env/bin/pip install --upgrade pip \
 && /opt/synthcity-env/bin/pip install torch==2.2.2+cpu synthcity ipykernel

# Register the virtual environment as a Jupyter kernel
RUN /opt/synthcity-env/bin/python -m ipykernel install --name synthcity --display-name "Python 3.10 (synthcity)"

# Add SynthCity env to PATH (optional)
ENV PATH="/opt/synthcity-env/bin:$PATH"

# Expose RStudio and Jupyter ports
EXPOSE 8787
EXPOSE 8888

# Placeholder: Start RStudio and Jupyter (users can replace with their own startup scripts)
CMD ["/init"]
